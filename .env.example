DATABASE_URL=postgresql://postgres:password@localhost:5432/marvticle-api
PORT=3000
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
VIEWER_IP_HASH_SALT=
CORS_ORIGIN=http://localhost:3001
LOG_LEVEL=debug
LOG_FORMAT=pretty
LOG_INCLUDE_DB_QUERIES=false
LOG_INCLUDE_AUTH_EVENTS=true
LOG_INCLUDE_REQUEST_BODY=false
LOG_INCLUDE_RESPONSE_BODY=false
LOG_SENSITIVE_FIELDS=password,token,secret,authorization,cookie
